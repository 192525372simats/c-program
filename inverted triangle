#include <stdio.h>
int main() {
    int rows, i, j;

    // Ask user for number of rows
    printf("Enter the number of rows: ");
    scanf("%d", &rows);

    // Generate inverted triangle
    for (i = rows; i >= 1; i--) {
        for (j = 1; j <= i; j++) {
            printf("* ");
        }
        printf("\n"); // Move to next line after each row
    }

    return 0;
