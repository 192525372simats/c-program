#include <stdio.h>
int main() {
    int rows, i, j, num = 1;

    // Ask user for number of rows
    printf("Enter the number of rows: ");
    scanf("%d", &rows);

    // Generate Floyd's Triangle
    for (i = 1; i <= rows; i++) {
        for (j = 1; j <= i; j++) {
            printf("%d ", num);
            num++;
        }
        printf("\n"); // Move to next line after each row
    }

    return 0;
}
